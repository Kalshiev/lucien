// Get a specific book by ID (replace {id} with the actual book ID)
GET http://localhost:8080/api/libraries/b54bf6f6-ed4b-4fdf-8c66-a0efcf03d007/books/1
####

// Update a book (replace {id} with the actual book ID)
PATCH http://localhost:8080/api/libraries/b54bf6f6-ed4b-4fdf-8c66-a0efcf03d007/books/1
Content-Type: application/json

{
  "title": "Tales of Mystery and Imagination (Updated Edition)",
  "author": "Edgar Allan Poe",
  "isbn": "978-0141036144"
}
####
// DELETE a book (replace {id} with the actual book ID)
DELETE http://localhost:8080/api/libraries/b54bf6f6-ed4b-4fdf-8c66-a0efcf03d007/books/1
