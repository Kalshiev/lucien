// Get all books in a library
GET http://localhost:8080/api/libraries/b54bf6f6-ed4b-4fdf-8c66-a0efcf03d007/books
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJsdWNpZW4tYWNjZXNzIiwic3ViIjoiM2Y0MzRmZDQtNDY3NS00NGViLWIzNmYtZTE1ZTNhZGUxYWEyIiwiZXhwIjoxNzgwMTcyMTUzLCJpYXQiOjE3ODAxNjg1NTN9.GC4qj0rasZamLm_OwG-Ht8XwFWF4ITq9JC6t_1cizKc

